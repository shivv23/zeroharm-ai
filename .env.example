# ZeroHarm AI Configuration
# Copy to .env and modify as needed

HOST=0.0.0.0
PORT=8000
WS_UPDATE_INTERVAL=2
RISK_TREND_MAX=60
HIGH_RISK_PERMIT_PENALTY=0.15
RAG_DEFAULT_TOP_K=3
LOG_LEVEL=INFO

# Security
API_KEY=change-me-to-a-random-string
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY_HOURS=24

# Database
DATABASE_URL=sqlite+aiosqlite:///zeroharm.db

# WebSocket limits
MAX_WS_CONNECTIONS=50
MAX_WS_MESSAGE_SIZE=65536

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Allowed origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Frontend (set at build time via REACT_APP_* — changes require rebuild)
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_API_URL=http://localhost:8000/api

# Alert Dispatch (optional — leave empty to disable)
SLACK_WEBHOOK_URL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
ALERT_SMS_TO=

# Vision (optional — leave empty to disable)
VISION_MODEL_PATH=yolov8n.pt
CCTV_RTSP_URLS=
