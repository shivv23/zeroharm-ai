# ZeroHarm AI Configuration
# Copy to .env and modify as needed
# Backend reads these via os.getenv() in constants.py

HOST=0.0.0.0
PORT=8000
WS_UPDATE_INTERVAL=2
RISK_TREND_MAX=60
HIGH_RISK_PERMIT_PENALTY=0.15
RAG_DEFAULT_TOP_K=3

# Frontend (set at build time via REACT_APP_*)
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_API_URL=http://localhost:8000/api

# RAG / Compliance thresholds are configured in backend/config/agent_settings.json
# Synthetic data parameters are in backend/config/sensors.json and backend/config/agent_settings.json
