# ZeroHarm AI Configuration
# Copy to .env and modify as needed

# Backend
HOST=0.0.0.0
PORT=8000
WS_UPDATE_INTERVAL=2
RISK_TREND_MAX=60

# Frontend (set at build time via REACT_APP_*)
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_API_URL=http://localhost:8000/api

# RAG Pipeline
RAG_DEFAULT_TOP_K=3
RAG_HOT_WORK_LEL_LIMIT=10
RAG_HOT_WORK_VOC_LIMIT=25
RAG_O2_SAFE_LOWER=19.5
RAG_O2_SAFE_UPPER=23.5
RAG_H2S_SAFE_LIMIT=5
RAG_HEIGHT_WORK_TEMP_LIMIT=50

# Compliance
COMPLIANCE_MAX_DEGRADATION=12.0
COMPLIANCE_DEGRADATION_PER_AUDIT=0.4
COMPLIANCE_BASE_DEGRADATION=3.0
COMPLIANCE_WARNING_VIOLATION_THRESHOLD=3
COMPLIANCE_WARNING_SCORE=70

# Compound Risk Engine
COMPOUND_RISK_CRITICAL_THRESHOLD=0.7
COMPOUND_RISK_HIGH_THRESHOLD=0.4
COMPOUND_RISK_WARNING_THRESHOLD=0.2

# Synthetic Data
RANDOM_SEED=42
PERMIT_GENERATION_PROB=0.15
COMPOUND_EVENT_PROB=0.05
SENSOR_NOISE_STD=0.08

# Knowledge Graph
KG_RISK_PATTERNS_SOURCE=config/agent_settings.json
